#!/bin/bash

if [[ -n "${BASH_VERSION:-}" ]]; then
  script_path="${BASH_SOURCE[0]}"
  script_sourced=false
  [[ "${script_path}" != "${0}" ]] && script_sourced=true
elif [[ -n "${ZSH_VERSION:-}" ]]; then
  script_path="${(%):-%x}"
  script_sourced=false
  [[ ":${ZSH_EVAL_CONTEXT:-}:" == *:file:* ]] && script_sourced=true
else
  script_path="${0}"
  script_sourced=false
fi

if [[ "${script_sourced}" != true ]]; then
  echo "Error: This script must be sourced, not executed directly." >&2
  echo "Usage: source ${script_path}" >&2
  echo "   or: . ${script_path}" >&2
  exit 1
fi

script_dir="$(cd -- "$(dirname -- "${script_path}")" && pwd -P)" || return 1
repo_root="$(cd -- "${script_dir}/.." && pwd -P)" || return 1
venv_dir="$(
  ruby -r "${repo_root}/lib/wifi-wand/docs_tooling" -e 'print WifiWand::DocsTooling.venv_dir'
)" || return 1

ruby -r "${repo_root}/lib/wifi-wand/docs_tooling" -e 'WifiWand::DocsTooling.setup_environment!' || return 1
source "${venv_dir}/bin/activate" || return 1

echo "Documentation environment ready."
echo "Activate later with: source ${venv_dir}/bin/activate"
