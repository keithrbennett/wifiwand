#!/usr/bin/env ruby
# frozen_string_literal: true

#
# Developer tool for building, signing, and notarizing the macOS helper.
# Replaces rake dev:* tasks with a cleaner CLI interface.
#
# This script stays in the repository for maintainers and is excluded from the distributed gem.
# It's run by the gem maintainer before releasing a new version.
# End users receive the pre-signed, pre-notarized helper binary.
#

require 'optparse'
require 'pathname'

module MacHelperCLI
  SCRIPT_PATH = File.realpath(__FILE__)
  SCRIPT_DIR = File.dirname(SCRIPT_PATH)
  REPO_ROOT = File.expand_path('..', SCRIPT_DIR)
  SUBCOMMANDS = {
    'build' => 'Build and sign helper with Developer ID (for gem distribution)',
    'verify' => 'Verify the committed helper bundle matches the current Swift source',
    'test' => 'Test the signed helper binary',
    'public-info' => 'Print public macOS signing and notarization configuration',
    'store-credentials' => 'Store notarytool credentials in the keychain',
    'notarize' => 'Notarize the helper for distribution (requires a notarytool keychain profile)',
    'release' => 'Complete release workflow: build, sign, test, notarize',
    'status' => 'Show code signing status of helper',
    'history' => 'Show recent notarization submissions (uses the configured notarytool profile)',
    'info' => 'Show notarization status for a submission (requires submission ID)',
    'log' => 'Show notarization log for a submission (requires submission ID)',
    'cancel' => 'Cancel a notarization submission (defaults to oldest queued submission)',
    'help' => 'Show this help message'
  }.freeze

  class CLI
    def initialize(args)
      @args = args
      @options = {
        submission_id: nil,
        order: nil,
        pending_only: nil
      }
    end

    def run
      subcommand = @args.shift

      if subcommand.nil? || subcommand == 'help' || subcommand == '--help' || subcommand == '-h'
        show_help
        exit 0
      end

      unless SUBCOMMANDS.key?(subcommand)
        warn "Error: Unknown subcommand '#{subcommand}'"
        warn "Run 'bin/mac-helper-release help' for usage information."
        exit 1
      end

      parse_options(subcommand)

      execute_subcommand(subcommand)
    end

    private

    def show_help
      puts <<~HELP
        Usage: bin/mac-helper-release <subcommand> [options]

        Subcommands:
      HELP

      SUBCOMMANDS.each do |cmd, desc|
        puts "  #{cmd.ljust(12)} #{desc}"
      end

      puts <<~HELP

        Examples:

          Build & sign:
            bin/mac-helper-release build

          Verify source attestation:
            bin/mac-helper-release verify

          Test:
            bin/mac-helper-release test

          Show public signing info:
            bin/mac-helper-release public-info

          One-time secure credential setup:
            bin/mac-helper-release store-credentials

          Notarize:
            bin/mac-helper-release notarize

          Full workflow:
            bin/mac-helper-release release

          Notarization history:
            bin/mac-helper-release history

          Notarization status (specific submission):
            bin/mac-helper-release info --submission-id <uuid>

          Notarization log (specific submission):
            bin/mac-helper-release log --submission-id <uuid>

          Cancel oldest queued notarization:
            bin/mac-helper-release cancel

          Cancel specific notarization:
            bin/mac-helper-release cancel --submission-id <uuid>

        Note: Runtime notarization commands use a notarytool keychain profile.
        This keeps the app-specific password out of process argv.

        Options:
          --submission-id ID        Submission ID for info/log/cancel commands
          --order asc|desc          Order for automatic submission selection (asc=oldest first, desc=latest first, default: desc)
          --pending-only            Only select pending submissions for cancel command
          --help, -h                Show this help message

        Environment Variables:
          WIFIWAND_APPLE_DEV_ID           Apple ID email for store-credentials (optional prompt fallback)
          WIFIWAND_NOTARYTOOL_PROFILE      notarytool keychain profile name (default: wifiwand-notarytool)
          WIFIWAND_NOTARYTOOL_KEYCHAIN     custom keychain path for that profile (optional)
          WIFIWAND_CODESIGN_IDENTITY       Code signing identity (optional override)

        See docs/dev/MACOS_CODE_SIGNING_INSTRUCTIONS.md for the checklist and
        docs/dev/MACOS_CODE_SIGNING_CONTEXT.md for the full background.
      HELP
    end

    def parse_options(subcommand)
      parser = OptionParser.new do |opts|
        opts.banner = "Usage: bin/mac-helper-release #{subcommand} [options]"

        opts.on('--submission-id ID', 'Submission ID for info/log/cancel commands') do |id|
          @options[:submission_id] = id
        end

        opts.on('--order ORDER', %w[asc ascending desc descending], 'Order for automatic submission selection (asc=oldest first, desc=latest first)') do |order|
          @options[:order] = order.to_sym
        end

        opts.on('--pending-only', 'Only select pending submissions') do
          @options[:pending_only] = true
        end

        opts.on('-h', '--help', 'Show help for this subcommand') do
          puts opts
          exit 0
        end
      end

      parser.parse!(@args)
    rescue OptionParser::InvalidOption => e
      warn "Error: #{e.message}"
      warn "Run 'bin/mac-helper-release #{subcommand} --help' for usage information."
      exit 1
    end

    def execute_subcommand(subcommand)
      case subcommand
      when 'build'
        WifiWand::MacHelperRelease.build_signed_helper
      when 'verify'
        WifiWand::MacHelperRelease.verify_source_attestation!
      when 'test'
        WifiWand::MacHelperRelease.test_signed_helper
      when 'public-info'
        public_signing_info
      when 'store-credentials'
        store_notarytool_credentials
      when 'notarize'
        WifiWand::MacHelperRelease.notarize_helper
      when 'release'
        WifiWand::MacHelperRelease.release_helper
      when 'status'
        WifiWand::MacHelperRelease.codesign_status
      when 'history'
        WifiWand::MacHelperRelease.notarization_history
      when 'info'
        submission_id = fetch_submission_id(order: :desc, pending_only: false)
        WifiWand::MacHelperRelease.notarization_status(submission_id)
      when 'log'
        submission_id = fetch_submission_id(order: :desc, pending_only: false)
        WifiWand::MacHelperRelease.notarization_log(submission_id)
      when 'cancel'
        submission_id = fetch_submission_id(order: :asc, pending_only: true)
        WifiWand::MacHelperRelease.cancel_notarization(submission_id)
      end
    rescue => e
      warn "Error: #{e.message}"
      warn e.backtrace.join("\n") if ENV['DEBUG']
      exit 1
    end

    def fetch_submission_id(order:, pending_only:)
      # Use provided submission ID if available
      return @options[:submission_id] if @options[:submission_id] && !@options[:submission_id].empty?

      # Override order if specified in options
      order = @options[:order] if @options[:order]
      pending_only = @options[:pending_only] unless @options[:pending_only].nil?

      # Auto-select from history
      normalized_order = WifiWand::MacHelperRelease.normalize_submission_order(order)
      auto_id = WifiWand::MacHelperRelease.select_submission_id(
        order: normalized_order,
        pending_only: pending_only
      )

      unless auto_id
        warn 'Error: No submission ID provided and unable to auto-select from history.'
        warn 'Provide --submission-id <uuid> or ensure there are submissions in history.'
        exit 1
      end

      adjective = normalized_order == :asc ? 'oldest' : 'latest'
      pending_msg = pending_only ? ' pending' : ''
      puts "Info: No submission ID provided; using #{adjective}#{pending_msg} notary submission #{auto_id}."
      auto_id
    end

    def public_signing_info
      WifiWand::MacHelperRelease::Operations.require_macos!(__method__.to_s)

      helper = WifiWand::MacOsHelperBundle
      profile_name = ENV.fetch(
        'WIFIWAND_NOTARYTOOL_PROFILE',
        WifiWand::MacHelperRelease::DEFAULT_NOTARYTOOL_PROFILE
      )
      keychain_path = ENV['WIFIWAND_NOTARYTOOL_KEYCHAIN']
      helper_exec_path = File.join(helper.source_bundle_path, 'Contents', 'MacOS', helper::EXECUTABLE_NAME)

      puts <<~INFO
        Public macOS signing and notarization info:
          Team ID: #{WifiWand::MacHelperRelease::APPLE_TEAM_ID}
          Codesign identity: #{WifiWand::MacHelperRelease::CODESIGN_IDENTITY}
          Notarytool profile: #{profile_name}
          Keychain path: #{keychain_path || '(login keychain default)'}
          Helper bundle path: #{helper.source_bundle_path}
          Helper executable path: #{helper_exec_path}
      INFO
    end

    def store_notarytool_credentials
      WifiWand::MacHelperRelease::Operations.require_macos!(__method__.to_s)

      apple_id = fetch_apple_dev_id
      profile_name = ENV.fetch(
        'WIFIWAND_NOTARYTOOL_PROFILE',
        WifiWand::MacHelperRelease::DEFAULT_NOTARYTOOL_PROFILE
      )
      keychain_path = ENV['WIFIWAND_NOTARYTOOL_KEYCHAIN']

      command = [
        'xcrun',
        'notarytool',
        'store-credentials',
        profile_name,
        '--apple-id',
        apple_id,
        '--team-id',
        WifiWand::MacHelperRelease::APPLE_TEAM_ID
      ]
      command += ['--keychain', keychain_path] if keychain_path && !keychain_path.empty?

      puts 'Storing notarytool credentials in the keychain...'
      puts "  Profile: #{profile_name}"
      puts "  Apple ID: #{apple_id}"
      puts "  Team ID: #{WifiWand::MacHelperRelease::APPLE_TEAM_ID}"
      puts "  Keychain path: #{keychain_path || '(login keychain default)'}"
      puts '  notarytool will prompt for the app-specific password.'

      success = system(*command)
      abort 'Failed to store notarytool credentials.' unless success
    end

    def fetch_apple_dev_id
      apple_id = ENV['WIFIWAND_APPLE_DEV_ID']
      return apple_id unless apple_id.nil? || apple_id.empty?

      print 'Apple ID email for notarytool: '
      entered = $stdin.gets
      apple_id = entered&.strip
      return apple_id unless apple_id.nil? || apple_id.empty?

      abort 'Set WIFIWAND_APPLE_DEV_ID or enter your Apple ID email when prompted.'
    end
  end
end

# Add lib to load path using the script-specific namespace so repeated loads do
# not leak shared constants into Object.
lib_path = Pathname.new(MacHelperCLI::REPO_ROOT).join('lib')
$LOAD_PATH.unshift(lib_path.to_s) unless $LOAD_PATH.include?(lib_path.to_s)

require 'wifi-wand/mac_helper/mac_helper_release'

# Run the CLI
MacHelperCLI::CLI.new(ARGV.dup).run if $PROGRAM_NAME == __FILE__
