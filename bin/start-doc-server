#!/usr/bin/env ruby
# frozen_string_literal: true

require_relative '../lib/wifi-wand/docs_tooling'

WifiWand::DocsTooling.ensure_mkdocs_available!

puts 'Starting documentation server...'
$stdout.flush
exec(WifiWand::DocsTooling.mkdocs_command, 'serve', '--config-file',
     WifiWand::DocsTooling.mkdocs_config_path, *ARGV)
