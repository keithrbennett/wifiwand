#!/bin/bash

set -euo pipefail

if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
  echo "Error: This script must be sourced, not executed directly." >&2
  echo "Usage: source bin/set-up-python-for-doc-server" >&2
  echo "   or: . bin/set-up-python-for-doc-server" >&2
  exit 1
fi

script_dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd -P)"
repo_root="$(cd -- "${script_dir}/.." && pwd -P)"
venv_dir="$(ruby -r "${repo_root}/lib/wifi-wand/docs_tooling" -e 'print WifiWand::DocsTooling.venv_dir')"

ruby -r "${repo_root}/lib/wifi-wand/docs_tooling" -e 'WifiWand::DocsTooling.setup_environment!'
source "${venv_dir}/bin/activate"

echo "Documentation environment ready."
echo "Activate later with: source ${venv_dir}/bin/activate"
