#!/usr/bin/env ruby
# frozen_string_literal: true

#
# Wrapper script for running commands with 1Password CLI environment injection.
# Loads secrets from .env.release (or custom file) and passes them to your command.
#
# Usage:
#   bin/op-wrap bundle exec rake dev:notarize_helper
#   bin/op-wrap bin/mac-helper notarize
#

module OpWrapScript
  SCRIPT_PATH = File.realpath(__FILE__)
  SCRIPT_DIR = File.dirname(SCRIPT_PATH)
  REPO_ROOT = File.expand_path('..', SCRIPT_DIR)

  def self.default_env_file
    File.expand_path('.env.release', REPO_ROOT)
  end

  def self.find_op_command
    ENV.fetch('WIFIWAND_OP_BIN', 'op')
  end

  def self.op_executable?(op_bin)
    if op_bin.include?(File::SEPARATOR)
      File.file?(op_bin) && File.executable?(op_bin)
    else
      ENV.fetch('PATH', '').split(File::PATH_SEPARATOR).any? do |dir|
        path = File.join(dir, op_bin)
        File.file?(path) && File.executable?(path)
      end
    end
  end

  def self.check_op_available!(op_bin)
    return if op_executable?(op_bin)

    warn "Error: 1Password CLI \"#{op_bin}\" not found in PATH."
    warn "Install op (https://developer.1password.com/docs/cli/) or set WIFIWAND_OP_BIN to its path."
    exit 1
  end

  def self.show_usage_and_exit
    warn "Usage: #{$PROGRAM_NAME} <command> [args...]"
    warn "Example: #{$PROGRAM_NAME} bundle exec rake dev:notarize_helper"
    warn "Example: #{$PROGRAM_NAME} bin/mac-helper notarize"
    exit 64
  end
end

if __FILE__ == $PROGRAM_NAME
  # Main execution
  op_bin = OpWrapScript.find_op_command
  env_file = ENV.fetch('WIFIWAND_OP_RUN_ENV', OpWrapScript.default_env_file)

  OpWrapScript.check_op_available!(op_bin)
  OpWrapScript.show_usage_and_exit if ARGV.empty?

  # Execute the command with 1Password environment injection
  exec(op_bin, 'run', "--env-file=#{env_file}", '--', *ARGV)
end
