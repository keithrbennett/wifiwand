#!/bin/bash

if [ -n "${BASH_VERSION:-}" ]; then
  script_path="${BASH_SOURCE[0]}"
  script_sourced=false
  [ "${script_path}" != "${0}" ] && script_sourced=true
elif [ -n "${ZSH_VERSION:-}" ]; then
  script_path="${(%):-%x}"
  script_sourced=false
  case ":${ZSH_EVAL_CONTEXT:-}:" in
    *:file:*) script_sourced=true ;;
  esac
else
  script_path="bin/set-up-python-for-doc-server"
  script_sourced=false
fi

if [ "${script_sourced}" != true ]; then
  echo "Error: This script must be sourced, not executed directly." >&2
  echo "Usage: source ${script_path}" >&2
  echo "   or: . ${script_path}" >&2
  if [ -z "${BASH_VERSION:-}${ZSH_VERSION:-}" ]; then
    return 1 2>/dev/null || exit 1
  fi

  exit 1
fi

script_dir="$(cd -- "$(dirname -- "${script_path}")" && pwd -P)" || return 1
repo_root="$(cd -- "${script_dir}/.." && pwd -P)" || return 1

run_docs_tooling_ruby() {
  env -i \
    HOME="${HOME:-}" \
    PATH="${PATH:-/usr/bin:/bin}" \
    LANG="${LANG:-}" \
    LC_ALL="${LC_ALL:-}" \
    TMPDIR="${TMPDIR:-}" \
    WIFIWAND_DOCS_MKDOCS="${WIFIWAND_DOCS_MKDOCS:-}" \
    WIFIWAND_DOCS_PYTHON="${WIFIWAND_DOCS_PYTHON:-}" \
    WIFIWAND_DOCS_VENV_DIR="${WIFIWAND_DOCS_VENV_DIR:-}" \
    ruby -r "${repo_root}/lib/wifi-wand/docs_tooling" "$@"
}

venv_dir="$(
  run_docs_tooling_ruby -e 'print WifiWand::DocsTooling.venv_dir'
)" || return 1

run_docs_tooling_ruby -e 'WifiWand::DocsTooling.setup_environment!' || return 1
source "${venv_dir}/bin/activate" || return 1

echo "Documentation environment ready."
echo "Activate later with: source ${venv_dir}/bin/activate"
